#!/usr/bin/env bash
set -euo pipefail

# Build and run Claude Code in a persistent container.
# Usage:
#   cj              — start container, attach a shell
#   cj build        — force rebuild the image, then start
#   cj sync         — copy changes from container back to host
#   cj refresh      — re-copy project from host into container (destructive)
#   cj destroy      — stop and remove the container for this project

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE_NAME="claude-jail"
CONTAINER_NAME="claude-$(basename "$(pwd)" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g')"

fix_worktree_git() {
  if [ -f "$(pwd)/.git" ]; then
    MAIN_GIT_DIR="$(git rev-parse --git-common-dir)"
    WORKTREE_GIT_DIR="$(git rev-parse --git-dir)"

    podman exec "$CONTAINER_NAME" rm /home/cj/project/.git
    podman exec "$CONTAINER_NAME" mkdir -p /home/cj/project/.git
    podman cp "$MAIN_GIT_DIR/objects" "$CONTAINER_NAME:/home/cj/project/.git/objects"
    podman cp "$MAIN_GIT_DIR/refs" "$CONTAINER_NAME:/home/cj/project/.git/refs"
    podman cp "$MAIN_GIT_DIR/packed-refs" "$CONTAINER_NAME:/home/cj/project/.git/packed-refs" 2>/dev/null || true
    podman cp "$MAIN_GIT_DIR/config" "$CONTAINER_NAME:/home/cj/project/.git/config"
    podman cp "$WORKTREE_GIT_DIR/HEAD" "$CONTAINER_NAME:/home/cj/project/.git/HEAD"
    podman cp "$WORKTREE_GIT_DIR/index" "$CONTAINER_NAME:/home/cj/project/.git/index" 2>/dev/null || true
  fi
}

FORCE_BUILD=false
if [ "${1:-}" = "build" ]; then
  FORCE_BUILD=true
  shift
fi

# ── Sync changes from container back to host ─────────────────────────
if [ "${1:-}" = "sync" ]; then
  if ! podman ps -q -f name="^${CONTAINER_NAME}$" | grep -q .; then
    echo "Error: container $CONTAINER_NAME is not running." >&2
    exit 1
  fi
  echo "Syncing changes from $CONTAINER_NAME to $(pwd)..."

  # Get all changed files from the container
  STATUS=$(podman exec -w /home/cj/project "$CONTAINER_NAME" \
    git status --porcelain -uall)
  if [ -z "$STATUS" ]; then
    echo "No changes to sync."
    exit 0
  fi

  # Delete locally any files deleted in the container
  echo "$STATUS" | grep '^ D ' | sed 's/^...//' | while IFS= read -r f; do
    [ -n "$f" ] && rm -f "$(pwd)/$f" && echo "  deleted: $f"
  done || true

  # Copy modified/added files one by one
  MODIFIED=$(echo "$STATUS" | grep -v '^ D ' | sed 's/^...//' || true)
  if [ -z "$MODIFIED" ]; then
    echo "Done. Review changes with 'git diff'."
    exit 0
  fi

  while IFS= read -r f; do
    [ -z "$f" ] && continue
    mkdir -p "$(dirname "$f")"
    podman cp "$CONTAINER_NAME:/home/cj/project/$f" "$f"
    echo "  synced: $f"
  done <<<"$MODIFIED"

  echo "Done. Review changes with 'git diff'."
  exit 0
fi

# ── Refresh project from host into container ─────────────────────────
if [ "${1:-}" = "refresh" ]; then
  if ! podman ps -q -f name="^${CONTAINER_NAME}$" | grep -q .; then
    echo "Error: container $CONTAINER_NAME is not running." >&2
    exit 1
  fi

  echo "WARNING: This will delete /home/cj/project in the container"
  echo "and replace it with the current host directory contents."
  echo "Any unsynchronized changes in the container will be lost."
  printf "\nContinue? [y/N] "
  read -r answer
  if [[ ! "$answer" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
  fi

  echo "Refreshing project in $CONTAINER_NAME..."
  podman exec -u 0 "$CONTAINER_NAME" rm -rf /home/cj/project
  podman exec "$CONTAINER_NAME" mkdir -p /home/cj/project
  podman cp "$(pwd)/." "$CONTAINER_NAME:/home/cj/project"
  fix_worktree_git
  podman exec -u 0 "$CONTAINER_NAME" chown -R cj:cj /home/cj/project
  echo "Done."
  exit 0
fi

# ── Destroy container ─────────────────────────────────────────────────
if [ "${1:-}" = "destroy" ]; then
  if ! podman ps -aq -f name="^${CONTAINER_NAME}$" | grep -q .; then
    echo "No container found for $CONTAINER_NAME."
    exit 0
  fi
  echo "Stopping and removing $CONTAINER_NAME..."
  podman rm -f "$CONTAINER_NAME" >/dev/null
  echo "Done."
  exit 0
fi

# ── Reuse running container if it exists ──────────────────────────────
if podman ps -q -f name="^${CONTAINER_NAME}$" | grep -q .; then
  echo "Container $CONTAINER_NAME is already running. Attaching..."
  exec podman exec -w /home/cj/project -it "$CONTAINER_NAME" zsh
fi

# ── Build (only if image doesn't exist) ───────────────────────────────
if $FORCE_BUILD || ! podman image exists "$IMAGE_NAME"; then
  echo "Building image..."
  podman build -t "$IMAGE_NAME" "$SCRIPT_DIR"
else
  echo "Image $IMAGE_NAME already exists, skipping build."
fi

# Clean up stopped container with same name
if podman ps -aq -f name="^${CONTAINER_NAME}$" | grep -q .; then
  echo "Removing stopped container..."
  podman rm "$CONTAINER_NAME" >/dev/null
fi

# ── Collect read-only mounts ──────────────────────────────────────────
MOUNTS=()

# GitHub CLI auth
if [ -d "$HOME/.config/gh" ]; then
  MOUNTS+=(-v "$HOME/.config/gh:/home/cj/.config/gh:ro")
fi

# Git config
if [ -f "$HOME/.gitconfig" ]; then
  MOUNTS+=(-v "$HOME/.gitconfig:/home/cj/.gitconfig:ro")
fi

# ── Start container in background ─────────────────────────────────────
echo "Starting container..."
PROJECT_NAME="$(basename "$(pwd)")"
podman run -d \
  --name "$CONTAINER_NAME" \
  -e "JAIL_PROJECT=$PROJECT_NAME" \
  "${MOUNTS[@]}" \
  "$IMAGE_NAME" >/dev/null

# ── Copy host config into container (writable copies) ────────────────
# Everything is copied, not mounted — container gets write access but
# can't modify host files. Keeps --dangerously-skip-permissions isolated.

# Claude config (settings, plugins, hooks, project memory)
podman cp "$HOME/.claude/." "$CONTAINER_NAME:/home/cj/.claude"

# Claude user-level config (MCPs, preferences)
if [ -f "$HOME/.claude.json" ]; then
  podman cp "$HOME/.claude.json" "$CONTAINER_NAME:/home/cj/.claude.json"
fi

# GCP credentials — gcloud needs to write token refresh files
if [ -d "$HOME/.config/gcloud" ]; then
  podman cp "$HOME/.config/gcloud/." "$CONTAINER_NAME:/home/cj/.config/gcloud"
fi

# Rewrite hardcoded host home paths to match container home
podman exec "$CONTAINER_NAME" find /home/cj/.claude -type f -name '*.json' \
  -exec sed -i "s|$HOME|/home/cj|g" {} +
# Rewrite .claude.json: keep only current project (remapped to /home/cj/project), drop others
HOST_PROJECT_DIR="$(pwd)"
podman exec "$CONTAINER_NAME" bash -c "
  jq --arg host '$HOST_PROJECT_DIR' '
    .projects = (if .projects[\$host] then {\"/home/cj/project\": .projects[\$host]} else {} end)
  ' /home/cj/.claude.json > /tmp/.claude.json.tmp && mv /tmp/.claude.json.tmp /home/cj/.claude.json
" 2>/dev/null || true

# Fix ownership — podman cp copies files as root
podman exec -u 0 "$CONTAINER_NAME" chown -R cj:cj /home/cj/.claude /home/cj/.claude.json /home/cj/.config/gcloud 2>/dev/null || true

podman exec "$CONTAINER_NAME" bash -c "git config --global --add safe.directory /home/cj/project"

# ── Copy project into container ───────────────────────────────────────
# Done last so we don't waste time on a large copy if mounts or config fail.
echo "Copying project into container..."
podman cp "$(pwd)/." "$CONTAINER_NAME:/home/cj/project"

fix_worktree_git

# Fix ownership for project — podman cp copies files as root
podman exec -u 0 "$CONTAINER_NAME" chown -R cj:cj /home/cj/project

# ── Attach a shell ────────────────────────────────────────────────────
echo "Container running. Attaching shell (exit won't stop the container)..."
echo "Run 'claude --dangerously-skip-permissions' inside to start Claude."
exec podman exec -w /home/cj/project -it "$CONTAINER_NAME" zsh
